# Physical to Virtual Meter Mappings - EXAMPLE
#
# This file is AUTO-GENERATED by the discover_meter_mappings.py script.
# DO NOT EDIT MANUALLY.
#
# The discovery script:
# 1. Scans XML files for production totals
# 2. Matches physical meters to virtual meters by production total values
# 3. Creates/updates config/meter_mappings.yaml automatically
#
# Physical meters measure total consumption/production.
# Virtual meters contain VSE breakdown codes (CEL local vs Grid).
#
# When processing a virtual meter's production breakdown, the data
# is attributed to the corresponding physical meter using this mapping.
#
# Structure:
#   physical_meter_id (last 8 chars):
#     virtual_meter: "virtual_meter_id (last 8 chars)"
#
# Example mapping for a community with 3 members who have solar panels:

meter_mappings:
  "0123456A":
    virtual_meter: "08551234"
    # Physical meter 0123456A produces 150 kWh
    # Virtual meter 08551234 also shows 150 kWh (matched!)
    # Virtual meter provides breakdown: 100 kWh to CEL, 50 kWh to Grid

  "0234567B":
    virtual_meter: "08552345"
    # Physical meter 0234567B produces 200 kWh
    # Virtual meter 08552345 also shows 200 kWh (matched!)
    # Virtual meter provides breakdown: 80 kWh to CEL, 120 kWh to Grid

  "0345678C":
    virtual_meter: "08553456"
    # Physical meter 0345678C produces 175 kWh
    # Virtual meter 08553456 also shows 175 kWh (matched!)
    # Virtual meter provides breakdown: 90 kWh to CEL, 85 kWh to Grid

# Notes:
# - Virtual meter IDs typically start with "085" in the suffix
# - Discovery runs automatically before each batch processing
# - New members are detected and added automatically
# - No manual maintenance required
